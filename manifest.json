{
     "manifest_version": 3,
     "name": "Stack Tube For YouTube",
     "version": "1.0.0",
     "icons": {
          "32": "footage.png"
     },
     "background": {
          "service_worker": "background.js",
          "type": "module"
     },
     "action": {
          "default_icon": "footage.png",
          "default_title": "Stack Tube For YouTube",
          "default_popup": "popup.html"
     },
     "permissions": [
          "scripting",
          "activeTab"
     ],
     "host_permissions": [
          "https://*/*"
     ]
}