{
     "manifest_version": 3,
     "name": "Stack Tube - YouTube Tab Manager",
     "version": "1.1.0",
     "description": "Organize, save, and share your YouTube tabs. Create collections, generate shareable links, and manage videos effortlessly.",
     "icons": {
          "16": "assets/footage.png",
          "32": "assets/footage.png",
          "48": "assets/footage.png",
          "128": "assets/footage.png"
     },
     "background": {
          "service_worker": "background.js",
          "type": "module"
     },
     "action": {
          "default_icon": {
               "16": "assets/footage.png",
               "32": "assets/footage.png",
               "48": "assets/footage.png",
               "128": "assets/footage.png"
          },
          "default_title": "Stack Tube - YouTube Tab Manager",
          "default_popup": "popup.html"
     },
     "permissions": [
          "tabs",
          "storage",
          "scripting"
     ],
     "host_permissions": [
          "https://www.youtube.com/*",
          "https://youtu.be/*"
     ]
}